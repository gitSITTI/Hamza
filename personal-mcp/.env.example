# Personal MCP — copy this to .env and fill in values
# Run: node scripts/setup.js  (auto-generates MCP_API_KEY and DB_SECRET)

PORT=3333

# Generated by setup.js — used by NetWorth GUI and Claude Code to authenticate
MCP_API_KEY=

# DB encryption passphrase — generated by setup.js, keep this secret
DB_SECRET=

# ── Free API keys ──────────────────────────────────────────────
# Rentcast: https://app.rentcast.io/app/api-keys (free tier = 500 req/mo)
RENTCAST_API_KEY=

# FRED (mortgage rates): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Polygon.io (stocks EOD): https://polygon.io/dashboard (free tier)
POLYGON_API_KEY=

# HUD (fair market rents): https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_API_KEY=

# Notion (for Notion sync): https://www.notion.so/my-integrations
NOTION_API_KEY=

# CoinGecko — no key needed for free tier (leave blank)
COINGECKO_API_KEY=

# ── Optional / Paid ────────────────────────────────────────────
# Zillow Bridge (paid ~$50/mo): https://bridgedataoutput.com
ZILLOW_API_KEY=

# Plaid (live bank feeds): https://dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
