# Copy to local-networthgui/.env for local development.
# Do not commit real key values. Put deployed values in GitHub repository secrets.

# BEA API: https://www.bea.gov/API/signup/index.cfm
BEA_API_KEY=

# Congress.gov / api.data.gov: https://gpo.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=

# FEC API: https://api.open.fec.gov/developers/
FEC_API_KEY=

# HUD USER API: https://www.huduser.gov/portal/dataset/api-terms-of-service.html
HUDUSER_API_KEY=

# Regulations.gov: https://open.gsa.gov/api/regulationsgov/
REGULATIONS_GOV_API_KEY=

# GovInfo API: https://api.govinfo.gov/docs/
GOVINFO_API_KEY=

# Optional Census key. Some Census endpoints work without one, but a key is useful for quota/reliability.
CENSUS_API_KEY=

# Official PACER access is account-gated and may incur fees. Prefer RECAP/CourtListener when possible.
PACER_ACCOUNT=
