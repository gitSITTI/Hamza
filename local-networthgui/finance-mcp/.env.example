# Copy to finance-mcp/.env for local development. Do not commit real values.

# Where the personal-finance store (finance-profile.json) is read/written.
# Defaults to <finance-mcp>/data when unset.
# FINANCE_MCP_DATA_DIR=

# Root of the Net Worth GUI that seed_networth_settings writes into.
# Defaults to the parent local-networthgui directory when unset.
# NETWORTHGUI_DIR=
